<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.paint.Color?>

<!-- Giao diện 950x600: Phong cách Hoàng gia Châu Âu, Đen sâu và Vàng Gold -->
<VBox minHeight="600.0" minWidth="950.0" prefHeight="600.0" prefWidth="950.0"
      style="-fx-background-color: #0A0A0A; -fx-border-color: #C5A059; -fx-border-width: 3; -fx-border-style: solid;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.quanlynhahang.controllers.KitchenController">
    <children>
        <!-- Header: Đỉnh cao thượng hạng với hiệu ứng Bling cho tiêu đề -->
        <VBox alignment="CENTER" prefHeight="80.0" style="-fx-background-color: linear-gradient(to bottom, #1A1A1A, #000000); -fx-border-color: #C5A059; -fx-border-width: 0 0 2 0;">
            <children>
                <Label text="L'ÉLITE CUISINE" style="-fx-font-weight: bold; -fx-text-fill: #C5A059; -fx-letter-spacing: 6;">
                    <font><Font name="Georgia Bold" size="26.0" /></font>
                    <effect>
                        <DropShadow radius="15" spread="0.3">
                            <color><Color red="0.77" green="0.62" blue="0.35" opacity="0.6" /></color>
                        </DropShadow>
                    </effect>
                </Label>
                <Label fx:id="lblDateTime" text="Mardi, 05 Mai 2026 | LUXURY SERVICE" style="-fx-text-fill: #E3C37D; -fx-font-size: 11; -fx-letter-spacing: 2; -fx-opacity: 0.8;" />
            </children>
        </VBox>

        <!-- Navigation: Nút bấm bọc viền vàng -->
        <HBox alignment="CENTER" spacing="20" style="-fx-padding: 15 0 10 0;">
            <Button fx:id="btnOrderView" onAction="#showOrderView" prefHeight="35.0" prefWidth="160.0" text="LES ORDRES"
                    style="-fx-background-color: #C5A059; -fx-text-fill: black; -fx-font-weight: bold; -fx-background-radius: 0; -fx-border-color: #8E6D2D; -fx-cursor: hand; -fx-font-family: 'Georgia';" />
            <Button fx:id="btnMenuView" onAction="#showMenuView" prefHeight="35.0" prefWidth="160.0" text="LE MENU"
                    style="-fx-background-color: transparent; -fx-text-fill: #C5A059; -fx-font-weight: bold; -fx-background-radius: 0; -fx-border-color: #C5A059; -fx-cursor: hand; -fx-font-family: 'Georgia';" />
        </HBox>

        <!-- DASHBOARD: 3 Ô Thống kê số lượng (TỚ MỚI THÊM VÀO ĐÂY) -->
        <HBox alignment="CENTER" spacing="30" style="-fx-padding: 5 0 15 0;">
            <children>
                <!-- Ô Pending -->
                <VBox alignment="CENTER" prefHeight="70.0" prefWidth="180.0"
                      style="-fx-background-color: #151515; -fx-border-color: #444; -fx-border-width: 1; -fx-border-radius: 8;">
                    <children>
                        <Label text="CHỜ CHẾ BIẾN" style="-fx-text-fill: #E3C37D; -fx-font-size: 10; -fx-font-family: 'Georgia'; -fx-letter-spacing: 1;" />
                        <Label fx:id="lblCountPending" text="0" style="-fx-text-fill: #C5A059; -fx-font-size: 24; -fx-font-weight: bold;">
                            <effect><DropShadow radius="5" color="#C5A059" /></effect>
                        </Label>
                    </children>
                </VBox>

                <!-- Ô Cooking (Vàng Gold rực rỡ) -->
                <VBox alignment="CENTER" prefHeight="70.0" prefWidth="180.0"
                      style="-fx-background-color: #1A1A1A; -fx-border-color: #C5A059; -fx-border-width: 2; -fx-border-radius: 8;">
                    <children>
                        <Label text="ĐANG THỰC HIỆN" style="-fx-text-fill: #FFD700; -fx-font-size: 10; -fx-font-family: 'Georgia'; -fx-letter-spacing: 1;" />
                        <Label fx:id="lblCountProcessing" text="0" style="-fx-text-fill: #FFD700; -fx-font-size: 24; -fx-font-weight: bold;">
                            <effect><DropShadow radius="10" color="#FFD700" /></effect>
                        </Label>
                    </children>
                </VBox>

                <!-- Ô Hoàn thành -->
                <VBox alignment="CENTER" prefHeight="70.0" prefWidth="180.0"
                      style="-fx-background-color: #151515; -fx-border-color: #444; -fx-border-width: 1; -fx-border-radius: 8;">
                    <children>
                        <Label text="HOÀN THÀNH" style="-fx-text-fill: #4CAF50; -fx-font-size: 10; -fx-font-family: 'Georgia'; -fx-letter-spacing: 1;" />
                        <Label fx:id="lblCountDone" text="0" style="-fx-text-fill: #4CAF50; -fx-font-size: 24; -fx-font-weight: bold;">
                            <effect><DropShadow radius="5" color="#4CAF50" /></effect>
                        </Label>
                    </children>
                </VBox>
            </children>
        </HBox>

        <StackPane VBox.vgrow="ALWAYS" style="-fx-padding: 0 20 20 20;">
            <!-- MÀN HÌNH 1: ĐIỀU PHỐI BẾP -->
            <GridPane fx:id="paneOrderView" hgap="15">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33.3" />
                    <ColumnConstraints percentWidth="33.3" />
                    <ColumnConstraints percentWidth="33.3" />
                </columnConstraints>
                <children>
                    <VBox spacing="10" GridPane.columnIndex="0" style="-fx-background-color: #151515; -fx-border-color: #444; -fx-padding: 12; -fx-border-radius: 5;">
                        <Label text="✧ PENDING ✧" style="-fx-text-fill: #C5A059; -fx-font-weight: bold; -fx-font-size: 14; -fx-font-family: 'Georgia';" alignment="CENTER" maxWidth="Infinity" />
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="vboxPending" spacing="10" style="-fx-background-color: transparent;" />
                            </content>
                        </ScrollPane>
                    </VBox>

                    <VBox spacing="10" GridPane.columnIndex="1" style="-fx-background-color: #1A1A1A; -fx-border-color: #C5A059; -fx-border-width: 2; -fx-padding: 12; -fx-border-radius: 5;">
                        <Label text="✧ EN CUISINE ✧" style="-fx-text-fill: #FFD700; -fx-font-weight: bold; -fx-font-size: 14; -fx-font-family: 'Georgia';" alignment="CENTER" maxWidth="Infinity">
                            <effect><DropShadow radius="10" color="#C5A059" /></effect>
                        </Label>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="vboxProcessing" spacing="10" style="-fx-background-color: transparent;" />
                            </content>
                        </ScrollPane>
                    </VBox>

                    <VBox spacing="10" GridPane.columnIndex="2" style="-fx-background-color: #151515; -fx-border-color: #444; -fx-padding: 12; -fx-border-radius: 5;">
                        <Label text="✧ TERMINÉ ✧" style="-fx-text-fill: #4CAF50; -fx-font-weight: bold; -fx-font-size: 14; -fx-font-family: 'Georgia';" alignment="CENTER" maxWidth="Infinity" />
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="vboxDone" spacing="10" style="-fx-background-color: transparent;" />
                            </content>
                        </ScrollPane>
                    </VBox>
                </children>
            </GridPane>

            <!-- MÀN HÌNH 2: THỰC ĐƠN -->
            <VBox fx:id="paneMenuView" visible="false" spacing="15" style="-fx-background-color: #111; -fx-padding: 20; -fx-border-color: #C5A059; -fx-border-width: 1;">
                <children>
                    <HBox alignment="CENTER_LEFT">
                        <children>
                            <Label text="GASTRONOMIE MENU" style="-fx-text-fill: #C5A059; -fx-font-weight: bold; -fx-font-size: 20; -fx-font-family: 'Georgia';" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button onAction="#handleAddNewDish" text="+ NOUVEAU PLAT"
                                    style="-fx-background-color: #C5A059; -fx-text-fill: black; -fx-font-weight: bold; -fx-padding: 8 20; -fx-font-size: 11; -fx-cursor: hand;" />
                        </children>
                    </HBox>
                    <TableView fx:id="tableMenu" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: #1A1A1A; -fx-control-inner-background: #1A1A1A; -fx-font-size: 12; -fx-border-color: #C5A059;">
                        <columns>
                            <TableColumn fx:id="colFoodName" prefWidth="250" text="PLATS D'ÉLITE" />
                            <TableColumn fx:id="colCategory" prefWidth="120" text="CATÉGORIE" />
                            <TableColumn fx:id="colStatus" prefWidth="120" text="STATUT" />
                            <TableColumn fx:id="colAction" prefWidth="120" text="MODIFIER" />
                        </columns>
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    </TableView>
                </children>
            </VBox>
        </StackPane>
    </children>
</VBox>