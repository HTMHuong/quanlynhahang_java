<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.Glow?>
<?import javafx.scene.shape.Line?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: #080808; -fx-border-color: #C5A059; -fx-border-width: 1;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.quanlynhahang.controllers.OrderStatusController">
    <!-- Header: Thanh lịch & Tối giản -->
    <top>
        <VBox alignment="CENTER" style="-fx-background-color: #000000; -fx-padding: 20;">
            <children>
                <Label text="L'ART CULINAIRE" textFill="#C5A059" style="-fx-letter-spacing: 8px;">
                    <font><Font name="Georgia" size="12.0" /></font>
                </Label>
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Line endX="50.0" stroke="#C5A059" strokeWidth="0.5" />
                        <Label text="TABLE NO." textFill="#C5A059" style="-fx-letter-spacing: 2px;">
                            <font><Font name="System Bold" size="20.0" /></font>
                        </Label>
                        <Label fx:id="lblTableNum" text="05" textFill="WHITE">
                            <font><Font name="Georgia Bold" size="28.0" /></font>
                            <effect><Glow level="0.5" /></effect>
                        </Label>
                        <Line endX="50.0" stroke="#C5A059" strokeWidth="0.5" />
                    </children>
                    <padding><Insets top="5" /></padding>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <HBox spacing="25.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="25.0" left="25.0" right="25.0" top="10.0" />
            </padding>
            <children>
                <!-- Nửa trái: Danh sách món (Gọn gàng) -->
                <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="ORDRE DU JOUR" textFill="#C5A059" style="-fx-letter-spacing: 3px;">
                            <font><Font name="Georgia Italic" size="14.0" /></font>
                        </Label>
                        <TableView fx:id="tableStatus" VBox.vgrow="ALWAYS" style="-fx-background-color: #111111; -fx-border-color: #333; -fx-border-width: 0.5;">
                            <columns>
                                <TableColumn fx:id="colMon" prefWidth="240.0" text="MENU DÉGUSTATION" />
                                <TableColumn fx:id="colSL" prefWidth="60.0" text="QTY" />
                                <TableColumn fx:id="colTrangThai" prefWidth="140.0" text="STATUS" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <!-- Nửa phải: Hóa đơn (Phong cách thiệp mời Châu Âu) -->
                <VBox prefWidth="380.0" spacing="15.0">
                    <children>
                        <!-- Member Card -->
                        <VBox alignment="CENTER_LEFT" spacing="8.0" style="-fx-background-color: linear-gradient(to bottom right, #1a1a1a, #000); -fx-padding: 15; -fx-border-color: #C5A059; -fx-border-width: 0.5;">
                            <children>
                                <Label text="PRIVILÈGE" textFill="#C5A059" style="-fx-letter-spacing: 2px;">
                                    <font><Font name="System Bold" size="10.0" /></font>
                                </Label>
                                <Label fx:id="lblCustomerInfo" text="M. Topping Luxury" textFill="WHITE">
                                    <font><Font name="Georgia" size="15.0" /></font>
                                </Label>
                                <Label fx:id="lblPoints" text="Points: 1.200 | Earned: +150" textFill="#888">
                                    <font><Font size="11.0"/></font>
                                </Label>
                            </children>
                        </VBox>

                        <!-- Bill Detail -->
                        <VBox spacing="12.0" style="-fx-background-color: #F8F5F0; -fx-padding: 25; -fx-background-radius: 2;" VBox.vgrow="ALWAYS">
                            <children>
                                <Label text="RECEPISSÉ" textFill="#1A1A1A" alignment="CENTER" maxWidth="Infinity" style="-fx-letter-spacing: 4px;">
                                    <font><Font name="Georgia Bold" size="16.0" /></font>
                                </Label>
                                <Line endX="280.0" stroke="#1A1A1A" strokeWidth="0.5" strokeDashArray="2, 2" />

                                <GridPane vgap="12.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" />
                                        <ColumnConstraints halignment="RIGHT" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="Subtotal" textFill="#444"><font><Font name="Georgia" size="13.0"/></font></Label>
                                        <Label fx:id="lblSubtotal" text="0 VNĐ" textFill="#1A1A1A" GridPane.columnIndex="1"><font><Font name="System Bold" size="13.0" /></font></Label>

                                        <Label text="Service Charge (10%)" textFill="#444" GridPane.rowIndex="1"><font><Font name="Georgia" size="13.0"/></font></Label>
                                        <Label fx:id="lblTax" text="0 VNĐ" textFill="#1A1A1A" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                        <Label text="Excellence Discount" textFill="#8E6E37" GridPane.rowIndex="2"><font><Font name="Georgia Italic" size="13.0"/></font></Label>
                                        <Label fx:id="lblDiscount" text="- 0 VNĐ" textFill="#B22222" GridPane.columnIndex="1" GridPane.rowIndex="2"><font><Font name="System Bold" size="13.0" /></font></Label>
                                    </children>
                                </GridPane>

                                <Region VBox.vgrow="ALWAYS" />
                                <Line endX="280.0" stroke="#C5A059" strokeWidth="1.0" />

                                <VBox alignment="CENTER" spacing="5.0">
                                    <children>
                                        <Label text="TOTAL À PAYER" textFill="#999" style="-fx-letter-spacing: 2px;">
                                            <font><Font name="System Bold" size="10.0" /></font>
                                        </Label>
                                        <Label fx:id="lblFinalTotal" text="0 VNĐ" textFill="#1A1A1A">
                                            <font><Font name="Georgia Bold" size="30.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                            <effect>
                                <DropShadow color="#00000022" radius="10" />
                            </effect>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="40.0" style="-fx-background-color: #000000; -fx-padding: 20; -fx-border-color: #C5A059; -fx-border-width: 1 0 0 0;">
            <children>
                <Button onAction="#handleAddNewDish" prefHeight="45.0" prefWidth="180.0"
                        style="-fx-background-color: transparent; -fx-border-color: #555; -fx-text-fill: #888; -fx-cursor: hand; -fx-border-radius: 0; -fx-font-family: 'Georgia';"
                        text="ADD MORE" />
                <Button fx:id="btnPay" onAction="#handlePayment" prefHeight="45.0" prefWidth="220.0"
                        style="-fx-background-color: #C5A059; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 0; -fx-font-weight: bold; -fx-letter-spacing: 2px;"
                        text="SETTLE BILL">
                    <effect>
                        <DropShadow color="#C5A05966" radius="10" />
                    </effect>
                </Button>
            </children>
        </HBox>
    </bottom>
</BorderPane>